# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# temporary file for convenience
TEMP.md

# email scripts with sensitive data
scripts/send-permission-confirmation.ts
scripts/already-emailed.json
scripts/.dedup-cache.json

# local scripts with hardcoded keys
scripts/*.mjs
