{
  "name": "claudemarketplaces.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "search": "bun run scripts/search.ts",
    "search:test": "bun run scripts/search.ts --limit 10",
    "search:dry": "bun run scripts/search.ts --dry-run",
    "search:skills": "bun run scripts/search-skills.ts",
    "search:skills:test": "bun run scripts/search-skills.ts --limit 10",
    "search:skills:dry": "bun run scripts/search-skills.ts --dry-run",
    "backfill": "bun --env-file=.env.prod run scripts/backfill-plugins.ts",
    "backfill:dry": "bun --env-file=.env.prod run scripts/backfill-plugins.ts --dry-run",
    "backfill:local": "bun run scripts/backfill-plugins.ts --dry-run",
    "seed": "bun run scripts/seed-supabase.ts",
    "indexnow": "bun run scripts/indexnow-submit.ts",
    "indexnow:skills": "bun run scripts/indexnow-submit.ts --filter /skills/",
    "indexnow:dry": "bun run scripts/indexnow-submit.ts --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "@hookform/resolvers": "^5.2.2",
    "@octokit/rest": "^22.0.0",
    "@openpanel/nextjs": "^1.3.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.545.0",
    "next": "15.5.9",
    "radix-ui": "^1.4.3",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "react-hook-form": "^7.73.1",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.4",
    "sanitize-html": "^2.17.3",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
